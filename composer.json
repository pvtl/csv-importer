{
    "name": "pvtl/csv-importer",
    "description": "Background CSV import via Laravel queue jobs",
    "type": "library",
    "license": "MIT",
    "version": "1.1.1",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/validation": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/console": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Pvtl\\CsvImporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pvtl\\CsvImporter\\CsvImporterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
